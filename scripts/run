#!/bin/sh
# Detect OS and architecture, then run the appropriate save-transcript binary.
# Downloads the binary from GitHub Releases on first run if not present.
# This shim is invoked by the Claude Code PreCompact hook.

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(dirname "$SCRIPT_DIR")"
BIN_DIR="$PLUGIN_ROOT/bin"
REPO="IDisposable/claude-transcript-plugin"

# Detect OS
case "$(uname -s)" in
    Linux*)   OS=linux ;;
    Darwin*)  OS=darwin ;;
    MINGW*|MSYS*|CYGWIN*) OS=windows ;;
    *)        OS=linux ;;
esac

# Detect architecture
case "$(uname -m)" in
    x86_64|amd64)  ARCH=amd64 ;;
    arm64|aarch64) ARCH=arm64 ;;
    *)             ARCH=amd64 ;;
esac

BINARY="$BIN_DIR/save-transcript-${OS}-${ARCH}"
if [ "$OS" = "windows" ]; then
    BINARY="${BINARY}.exe"
fi

# Bootstrap: download binary from GitHub Release if not present
if [ ! -f "$BINARY" ]; then
    VERSION=$(sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' \
        "$PLUGIN_ROOT/.claude-plugin/plugin.json" | head -1)
    if [ -z "$VERSION" ]; then
        echo "transcript-saver: cannot determine version from plugin.json" >&2
        exit 0
    fi

    FILENAME="save-transcript-${OS}-${ARCH}"
    if [ "$OS" = "windows" ]; then FILENAME="${FILENAME}.exe"; fi
    URL="https://github.com/${REPO}/releases/download/v${VERSION}/${FILENAME}"

    echo "transcript-saver: downloading binary for ${OS}/${ARCH} (v${VERSION})..." >&2
    mkdir -p "$BIN_DIR"
    if command -v curl >/dev/null 2>&1; then
        if ! curl -fsSL -o "$BINARY" "$URL"; then
            echo "transcript-saver: download failed from $URL" >&2
            rm -f "$BINARY"
            exit 0
        fi
    elif command -v wget >/dev/null 2>&1; then
        if ! wget -q -O "$BINARY" "$URL"; then
            echo "transcript-saver: download failed from $URL" >&2
            rm -f "$BINARY"
            exit 0
        fi
    else
        echo "transcript-saver: no curl or wget available, cannot download binary" >&2
        exit 0
    fi
    chmod +x "$BINARY"
fi

exec "$BINARY" "$@"
